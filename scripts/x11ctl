#!/usr/local/bin/python3
"""x11ctl — Manage X11 inside FreeBSD jails.

Single-file script (stdlib only, Python >=3.10) managing a 3-tier X11 stack:
  Tier 1 (Headless): Xvfb virtual framebuffer
  Tier 2 (Xpra):     Remote viewing via Xpra shadow + HTML5
  Tier 3 (VNC):      x11vnc + noVNC/websockify fallback
"""
from __future__ import annotations

import argparse
import fcntl
import os
import re
import shutil
import signal
import socket
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass, field
from pathlib import Path
from typing import Callable, Optional


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

_DISPLAY_RE = re.compile(r"^:\d+$")
_SCREEN_RE = re.compile(r"^\d+x\d+x\d+$")
_XAUTH_RE = re.compile(r"^/tmp/\.x11ctl-[^/]+$")


@dataclass(frozen=True)
class Config:
    """Immutable configuration built from env vars and defaults."""

    display: str = field(default_factory=lambda: os.environ.get("X11CTL_DISPLAY", ":99"))
    screen: str = field(default_factory=lambda: os.environ.get("X11CTL_SCREEN", "1920x1080x24"))
    bind: str = field(default_factory=lambda: os.environ.get("X11CTL_BIND", "127.0.0.1"))
    xpra_port: int = field(default_factory=lambda: int(os.environ.get("X11CTL_XPRA_PORT", "10000")))
    vnc_port: int = field(default_factory=lambda: int(os.environ.get("X11CTL_VNC_PORT", "5900")))
    novnc_port: int = field(default_factory=lambda: int(os.environ.get("X11CTL_NOVNC_PORT", "6080")))
    xauth: str = field(default_factory=lambda: "")
    state_prefix: str = field(default=".x11ctl")
    state_dir: str = field(default="")

    def __post_init__(self) -> None:
        # Validate display
        if not _DISPLAY_RE.match(self.display):
            raise ValueError(f"X11CTL_DISPLAY must match ^:\\d+$ (got {self.display!r})")
        # Validate screen
        if not _SCREEN_RE.match(self.screen):
            raise ValueError(f"X11CTL_SCREEN must match ^\\d+x\\d+x\\d+$ (got {self.screen!r})")
        # Validate and normalize xauth
        raw_xauth = os.environ.get("X11CTL_XAUTH", "")
        if raw_xauth:
            normalized = str(Path(raw_xauth).resolve(strict=False))
            if not _XAUTH_RE.match(normalized):
                raise ValueError(
                    f"X11CTL_XAUTH must resolve to /tmp/.x11ctl-<name> "
                    f"(got {raw_xauth!r} -> {normalized!r})"
                )
            object.__setattr__(self, "xauth", normalized)
        elif not self.xauth:
            object.__setattr__(self, "xauth", "/tmp/.x11ctl-xauth")

    @property
    def display_number(self) -> int:
        return int(self.display[1:])

    def pidfile(self, component: str) -> str:
        if self.state_dir:
            return os.path.join(self.state_dir, f"{self.state_prefix}-{component}.pid")
        return f"/tmp/{self.state_prefix}-{component}.pid"

    def logfile(self, component: str) -> str:
        if self.state_dir:
            return os.path.join(self.state_dir, f"{self.state_prefix}-{component}.log")
        return f"/tmp/{self.state_prefix}-{component}.log"

    @property
    def tiers_file(self) -> str:
        if self.state_dir:
            return os.path.join(self.state_dir, f"{self.state_prefix}-tiers")
        return f"/tmp/{self.state_prefix}-tiers"

    @property
    def lock_file(self) -> str:
        if self.state_dir:
            return os.path.join(self.state_dir, f"{self.state_prefix}.lock")
        return f"/tmp/{self.state_prefix}.lock"

    @classmethod
    def for_self_test(cls, display_num: int, state_dir: str) -> Config:
        """Factory for self-test configs. Pure path derivation, no side effects."""
        return cls(
            display=f":{display_num}",
            xpra_port=10000 + display_num,
            vnc_port=5900 + display_num,
            novnc_port=6080 + display_num,
            xauth=f"/tmp/.x11ctl-selftest-{display_num}",
            state_prefix=f".x11ctl-selftest-{display_num}",
            state_dir=state_dir,
        )


# ---------------------------------------------------------------------------
# Tier logic
# ---------------------------------------------------------------------------

_TIER_DEPS: dict[str, set[str]] = {
    "headless": {"headless"},
    "xpra": {"headless", "xpra"},
    "vnc": {"headless", "vnc"},
    "all": {"headless", "xpra", "vnc"},
}


def desired_tiers(tier: str) -> set[str]:
    """Return the set of tiers implied by a tier name."""
    return set(_TIER_DEPS.get(tier, set()))


# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------

def parse_args(argv: list[str]) -> argparse.Namespace:
    """Parse command-line arguments."""
    parser = argparse.ArgumentParser(
        prog="x11ctl",
        description="Manage X11 inside FreeBSD jails",
    )
    sub = parser.add_subparsers(dest="command")

    # start
    p_start = sub.add_parser("start", help="Start X11 components")
    p_start.add_argument("--headless", action="store_true")
    p_start.add_argument("--xpra", action="store_true")
    p_start.add_argument("--vnc", action="store_true")
    p_start.add_argument("--all", action="store_true")
    p_start.add_argument("--bind-all", action="store_true")

    # stop
    p_stop = sub.add_parser("stop", help="Stop X11 components")
    p_stop.add_argument("--headless", action="store_true")
    p_stop.add_argument("--xpra", action="store_true")
    p_stop.add_argument("--vnc", action="store_true")
    p_stop.add_argument("--all", action="store_true")

    # status
    sub.add_parser("status", help="Show running state")

    # env
    sub.add_parser("env", help="Print DISPLAY/XAUTHORITY exports")

    # run
    p_run = sub.add_parser("run", help="Run command with temporary Xvfb")
    p_run.add_argument("run_command", nargs=argparse.REMAINDER)

    # screenshot
    p_ss = sub.add_parser("screenshot", help="Capture display to PNG")
    p_ss.add_argument("path", help="Output PNG path")

    # setup
    p_setup = sub.add_parser("setup", help="Install packages")
    p_setup.add_argument("--tier1", action="store_true")
    p_setup.add_argument("--tier2", action="store_true")
    p_setup.add_argument("--tier3", action="store_true")
    p_setup.add_argument("--all", action="store_true")

    # self-test
    p_selftest = sub.add_parser("self-test", help="Run self-test")
    p_selftest.add_argument("--tier1", action="store_true")
    p_selftest.add_argument("--tier2", action="store_true")
    p_selftest.add_argument("--tier3", action="store_true")
    p_selftest.add_argument("--all", action="store_true")

    return parser.parse_args(argv)


# ---------------------------------------------------------------------------
# Pidfile I/O
# ---------------------------------------------------------------------------

def write_pidfile(path: str, pid: int, epoch: int) -> None:
    """Atomically write a pidfile. Rejects symlinks."""
    # Check target is not a symlink
    if os.path.lexists(path) and os.path.islink(path):
        raise OSError(f"Refusing to write pidfile over symlink: {path}")

    # Write to temp file in same directory, then atomic rename
    dir_path = os.path.dirname(path) or "/tmp"
    fd = tempfile.mkstemp(dir=dir_path, prefix=".pidfile-")
    try:
        os.write(fd[0], f"{pid} {epoch}\n".encode())
        os.close(fd[0])
        # Final symlink check before rename
        if os.path.lexists(path) and os.path.islink(path):
            os.unlink(fd[1])
            raise OSError(f"Refusing to write pidfile over symlink: {path}")
        os.rename(fd[1], path)
    except BaseException:
        try:
            os.unlink(fd[1])
        except FileNotFoundError:
            pass
        raise


def read_pidfile(path: str) -> Optional[tuple[int, int]]:
    """Read a pidfile. Returns (pid, epoch) or None. Rejects symlinks."""
    # Reject symlinks
    if os.path.islink(path):
        return None
    try:
        fd = os.open(path, os.O_RDONLY | os.O_NOFOLLOW)
        try:
            data = os.read(fd, 256).decode().strip()
        finally:
            os.close(fd)
        parts = data.split()
        if len(parts) != 2:
            return None
        return int(parts[0]), int(parts[1])
    except (FileNotFoundError, ValueError, OSError):
        return None


# ---------------------------------------------------------------------------
# Tiers file I/O
# ---------------------------------------------------------------------------

def write_tiers(path: str, tiers: set[str]) -> None:
    """Atomically write the active tiers set. Rejects symlinks."""
    if os.path.lexists(path) and os.path.islink(path):
        raise OSError(f"Refusing to write tiers file over symlink: {path}")

    dir_path = os.path.dirname(path) or "/tmp"
    fd = tempfile.mkstemp(dir=dir_path, prefix=".tiers-")
    try:
        os.write(fd[0], " ".join(sorted(tiers)).encode() + b"\n")
        os.close(fd[0])
        if os.path.lexists(path) and os.path.islink(path):
            os.unlink(fd[1])
            raise OSError(f"Refusing to write tiers file over symlink: {path}")
        os.rename(fd[1], path)
    except BaseException:
        try:
            os.unlink(fd[1])
        except FileNotFoundError:
            pass
        raise


def read_tiers(path: str) -> Optional[set[str]]:
    """Read the active tiers from file. Returns None if missing."""
    if os.path.islink(path):
        return None
    try:
        fd = os.open(path, os.O_RDONLY | os.O_NOFOLLOW)
        try:
            data = os.read(fd, 256).decode().strip()
        finally:
            os.close(fd)
        if not data:
            return None
        return set(data.split())
    except (FileNotFoundError, OSError):
        return None


def delete_tiers(path: str) -> None:
    """Delete the tiers file. Safe if missing."""
    try:
        os.unlink(path)
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# Locking
# ---------------------------------------------------------------------------

def acquire_lock(
    path: str, *, exclusive: bool = True, timeout: float = 30.0
) -> Optional[int]:
    """Acquire a file lock. Returns fd on success, None on timeout."""
    try:
        fd = os.open(path, os.O_CREAT | os.O_WRONLY, 0o644)
    except OSError:
        return None

    lock_type = fcntl.LOCK_EX if exclusive else fcntl.LOCK_SH
    deadline = time.monotonic() + timeout
    interval = 0.1

    while True:
        try:
            fcntl.flock(fd, lock_type | fcntl.LOCK_NB)
            return fd
        except BlockingIOError:
            if time.monotonic() >= deadline:
                os.close(fd)
                return None
            time.sleep(interval)


def release_lock(fd: int) -> None:
    """Release a file lock."""
    try:
        fcntl.flock(fd, fcntl.LOCK_UN)
        os.close(fd)
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Preflight
# ---------------------------------------------------------------------------

def find_binary(name: str) -> Optional[str]:
    """Find a binary on PATH. Returns full path or None."""
    return shutil.which(name)


def check_binaries(names: list[str]) -> list[str]:
    """Return list of missing binaries from the given names."""
    return [n for n in names if find_binary(n) is None]


# ---------------------------------------------------------------------------
# Port detection
# ---------------------------------------------------------------------------

def check_port_available(host: str, port: int) -> bool:
    """Check if a port is available by attempting to bind."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 0)
    try:
        sock.bind((host, port))
        return True
    except OSError:
        return False
    finally:
        sock.close()


def identify_port_user(port: int) -> Optional[str]:
    """Use sockstat to identify what process is using a port."""
    try:
        result = subprocess.run(
            ["sockstat", "-l", "-p", str(port)],
            capture_output=True, text=True, timeout=5,
        )
        lines = result.stdout.strip().split("\n")
        if len(lines) > 1:
            return lines[1]  # first data line after header
        return None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


# ---------------------------------------------------------------------------
# Env output
# ---------------------------------------------------------------------------

def format_env(cfg: Config) -> str:
    """Format DISPLAY and XAUTHORITY as shell export lines."""
    return (
        f'export DISPLAY="{cfg.display}"\n'
        f'export XAUTHORITY="{cfg.xauth}"\n'
    )


# ---------------------------------------------------------------------------
# Log rotation
# ---------------------------------------------------------------------------

def rotate_log(path: str) -> None:
    """Rotate log file: current -> .prev. Safe if missing."""
    try:
        os.rename(path, path + ".prev")
    except FileNotFoundError:
        pass


# ---------------------------------------------------------------------------
# Xauth
# ---------------------------------------------------------------------------

def create_xauth_file(path: str) -> None:
    """Create an xauth file with mode 0600. Rejects symlinks."""
    if os.path.lexists(path) and os.path.islink(path):
        raise OSError(f"Refusing to create xauth over symlink: {path}")

    # Remove existing regular file if present
    if os.path.exists(path):
        os.unlink(path)

    # Create with O_CREAT | O_EXCL | O_WRONLY | O_NOFOLLOW
    fd = os.open(path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
    os.close(fd)


# ---------------------------------------------------------------------------
# Readiness probes
# ---------------------------------------------------------------------------

def wait_ready(
    check: Callable[[], bool], *, retries: int = 10, delay: float = 0.5
) -> bool:
    """Poll a readiness check function. Returns True if check passes."""
    for _ in range(retries):
        if check():
            return True
        time.sleep(delay)
    return False


# ---------------------------------------------------------------------------
# Subcommands (stubs — implemented in later tasks)
# ---------------------------------------------------------------------------

def main() -> None:
    """Entry point."""
    args = parse_args(sys.argv[1:])
    if args.command is None:
        parse_args(["--help"])
        return
    print(f"x11ctl: command '{args.command}' not yet implemented", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
